generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  non_binary
}

enum AccountStatus {
  active
  banned
}

enum LikeStatus {
  pending
  matched
  expired
}

enum LikeType {
  direct
  invisible
  strong
}

enum PeerVote {
  yes
  no
}

enum ConversationState {
  active
  gated_to_video
  ended
  frozen
}

model User {
  id                        String             @id @default(cuid())
  email                     String             @unique
  passwordHash              String
  gender                    Gender
  age                       Int
  preferredAgeMin           Int?
  preferredAgeMax           Int?
  zip                       String
  cityId                    String
  city                      City               @relation(fields: [cityId], references: [id])
  isFrozen                  Boolean            @default(false)
  partnerId                 String?
  partner                   User?              @relation("PartnerLink", fields: [partnerId], references: [id])
  partneredBy               User[]             @relation("PartnerLink")
  accountStatus             AccountStatus      @default(active)
  riskFingerprintHash       String?
  lastActiveAt              DateTime           @default(now())
  mpsCurrent                Float              @default(1.0)
  scorePhysicality          Float              @default(1.0)
  scoreResources            Float              @default(1.0)
  scoreReliability          Float              @default(1.0)
  scoreSafety               Float              @default(1.0)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  peerReviewBypassUntil     DateTime?
  profile                   Profile?
  sentLikes                 Like[]             @relation("SentLikes")
  receivedLikes             Like[]             @relation("ReceivedLikes")
  participantAConversations Conversation[]     @relation("ParticipantA")
  participantBConversations Conversation[]     @relation("ParticipantB")
  sentMessages              Message[]
  writtenPeerReviews        PeerReview[]       @relation("WrittenReviews")
  receivedPeerReviews       PeerReview[]       @relation("ReceivedReviews")
  mpsHistory                MpsHistory[]
  dailyQuota                DailyQuota?
  profileDailyStats         ProfileDailyStat[] @relation("ProfileStats")
  hiddenUsers               HiddenProfile[]    @relation("HiddenUsers")
  hiddenByUsers             HiddenProfile[]    @relation("HiddenByUsers")
  waitlistState             WaitlistState?
  passSignals               PassSignal[]       @relation("PassSignalsByUser")
  passedBySignals           PassSignal[]       @relation("PassSignalsToUser")
}

model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  bio                String?
  prompts            String?
  photoMainUrl       String
  photoCapturedAt    DateTime
  incomeSelfReported Int      @default(0)
  heightCm           Int?
  weightKg           Int?
  profileCompletion  Int      @default(0)
  verificationStatus String   @default("unverified")
}

model Like {
  id         String     @id @default(cuid())
  fromUserId String
  toUserId   String
  fromUser   User       @relation("SentLikes", fields: [fromUserId], references: [id])
  toUser     User       @relation("ReceivedLikes", fields: [toUserId], references: [id])
  createdAt  DateTime   @default(now())
  expiresAt  DateTime
  status     LikeStatus @default(pending)
  type       LikeType   @default(direct)

  @@unique([fromUserId, toUserId])
}

model Conversation {
  id                String            @id @default(cuid())
  pairKey           String            @unique
  participantAId    String
  participantBId    String
  participantA      User              @relation("ParticipantA", fields: [participantAId], references: [id])
  participantB      User              @relation("ParticipantB", fields: [participantBId], references: [id])
  messageCountTotal Int               @default(0)
  state             ConversationState @default(active)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  messages          Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
  body           String
  createdAt      DateTime     @default(now())
}

model PeerReview {
  id               String   @id @default(cuid())
  raterUserId      String
  ratedUserId      String
  raterUser        User     @relation("WrittenReviews", fields: [raterUserId], references: [id])
  ratedUser        User     @relation("ReceivedReviews", fields: [ratedUserId], references: [id])
  vote             PeerVote
  createdAt        DateTime @default(now())

  @@unique([raterUserId, ratedUserId])
}

model City {
  id         String      @id @default(cuid())
  name       String
  zipPrefix  String      @unique
  threshold  Int         @default(1000)
  users      User[]
  cityStatus CityStatus?
  waitlistStates WaitlistState[]
}

model CityStatus {
  cityId           String   @id
  city             City     @relation(fields: [cityId], references: [id])
  totalUsersActive Int      @default(0)
  threshold        Int      @default(1000)
  updatedAt        DateTime @updatedAt
}

model MpsHistory {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  timestamp         DateTime @default(now())
  mpsValue          Float
  componentSnapshot String
}

model DailyQuota {
  userId               String   @id
  user                 User     @relation(fields: [userId], references: [id])
  likesRemaining       Int      @default(5)
  profilesShownToday   Int      @default(0)
  shownUserIdsJson     String   @default("[]")
  peerReviewsCompleted Int      @default(0)
  resetAt              DateTime
}

model ProfileDailyStat {
  id            String @id @default(cuid())
  profileUserId String
  profileUser   User   @relation("ProfileStats", fields: [profileUserId], references: [id])
  statDate      String
  likesReceived Int    @default(0)

  @@unique([profileUserId, statDate])
}

model HiddenProfile {
  id           String @id @default(cuid())
  userId       String
  hiddenUserId String
  user         User   @relation("HiddenUsers", fields: [userId], references: [id])
  hiddenUser   User   @relation("HiddenByUsers", fields: [hiddenUserId], references: [id])

  @@unique([userId, hiddenUserId])
}

model WaitlistState {
  userId                           String   @id
  user                             User     @relation(fields: [userId], references: [id])
  cityId                           String
  city                             City     @relation(fields: [cityId], references: [id])
  priorityScore                    Int      @default(0)
  priorityUpdatedAt                DateTime @default(now())
  reviewsCompletedSinceLastGate    Int      @default(0)
  nextEligibleAt                   DateTime?
  totalReviewsCompletedLifetime    Int      @default(0)
  updatedAt                        DateTime @updatedAt
}

model PassSignal {
  id           String   @id @default(cuid())
  userId       String
  targetUserId String
  user         User     @relation("PassSignalsByUser", fields: [userId], references: [id])
  targetUser   User     @relation("PassSignalsToUser", fields: [targetUserId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([userId, targetUserId])
}
